# ---- Python bytecode / caches ----
__pycache__/
*.py[cod]
*$py.class

# ---- Build / packaging ----
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Tool caches ----
.mypy_cache/
.pytest_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# ---- Notebook / REPL ----
.ipynb_checkpoints/

# ---- Logs ----
*.log
logs/

# ---- Local env/config ----
.env
.env.*
!.env.example

# ---- OS files ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Editors / IDE ----
.vscode/
.idea/
*.swp
*.swo

# ---- VideoDeck runtime data ----
uploads/
temp/
output/
videodeck.db
*.sqlite
*.sqlite3

# Keep folders if you add placeholders
!uploads/.gitkeep
!temp/.gitkeep
!output/.gitkeep
